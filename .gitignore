# secrets / env
*.env
.env*
!.env.example

# runtime / data — never publish
**/results/
**/queue-out/
*.log

# cascade runtime (worktrees, logs, claims) — live worker state, never publish
.cascade/

# escalation lockfile (escalate() flock — serializes D-NNN id minting)
director/DECISIONS.md.lock

# python / node junk
__pycache__/
*.pyc
node_modules/

# generated knowledge graph — regenerate locally with graphify, not maintained in-repo
graphify-out/

# generated repo index — deterministic, rewritten each digest cycle by local/map-gen.sh
director/MAP.md

# vm ssh keypair — local credential, pairs with the golden image
evals/agentic/ssh/

# vm/proxy runtime + generated smoke report
evals/agentic/build/
evals/agentic/smoke.md

# local planning scratch — kept on device, not published
plan/
