# Apkallu inference config — provider-agnostic (OpenAI-compatible endpoints).
# Copy to .env and fill in. .env is gitignored; nothing here is a real secret.

# Host of your OpenAI-compatible inference API — a remote provider, or a local
# server such as llama.cpp / vLLM / Ollama.
LLM_UPSTREAM_HOST=

# API key for that endpoint. May also live in evals/agentic/.secrets.env.
# The host-side proxy injects it so the key never enters the VM.
LLM_API_KEY=

# Default model slug (override per run with --model).
LLM_MODEL=

# Optional: comma-separated models the smoke test exercises.
# LLM_SMOKE_MODELS=

# PATH CONSTRAINT (known limitation): the bundled proxy forwards the upstream path
# "/openai/v1" verbatim. Endpoints that use a different path ("/v1", "/api/v1", ...)
# are not supported yet — a full LLM_BASE_URL (scheme + host + path) is planned.
# Until then, only endpoints exposing "/openai/v1" work unmodified.
