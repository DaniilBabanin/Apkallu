# Apkallu inference config — provider-agnostic (OpenAI-compatible endpoints).
# Copy to .env and fill in. .env is gitignored; nothing here is a real secret.

# Full upstream URL of your OpenAI-compatible inference API — scheme + host + path —
# a remote provider or a local server (llama.cpp / vLLM / Ollama). The proxy remaps any
# upstream path, so /openai/v1, /v1, /api/v1, ... all work. Preferred.
#   e.g. https://api.example.com/openai/v1   or   http://localhost:11434/v1
LLM_BASE_URL=

# Legacy alternative to LLM_BASE_URL: host only (implies https + the /openai/v1 path).
# Set LLM_BASE_URL OR this — LLM_BASE_URL wins if both are set.
# LLM_UPSTREAM_HOST=

# API key for that endpoint. May also live in evals/agentic/.secrets.env.
# The host-side proxy injects it so the key never enters the VM.
LLM_API_KEY=

# Default model slug (override per run with --model).
LLM_MODEL=

# Optional: comma-separated models the smoke test exercises.
# LLM_SMOKE_MODELS=
