# Apkallu inference config — provider-agnostic (OpenAI-compatible endpoints).
# Copy to .env and fill in. .env is gitignored; nothing here is a real secret.

# Full upstream URL of your OpenAI-compatible inference API — scheme + host + path —
# a remote provider or a local server (llama.cpp / vLLM / Ollama). The proxy remaps any
# upstream path, so /openai/v1, /v1, /api/v1, ... all work. Preferred.
#   e.g. https://api.example.com/openai/v1   or   http://localhost:11434/v1
LLM_BASE_URL=

# Legacy alternative to LLM_BASE_URL: host only (implies https + the /openai/v1 path).
# Set LLM_BASE_URL OR this — LLM_BASE_URL wins if both are set.
# LLM_UPSTREAM_HOST=

# API key for that endpoint. May also live in evals/agentic/.secrets.env.
# The host-side proxy injects it so the key never enters the VM.
LLM_API_KEY=

# --- Choosing a model for the agentic coding lane (evals/agentic) ---
# The in-VM agent (OpenHands) sends a large system prompt + tool schemas (~6-8k tokens) every turn,
# so the model needs tool-calling AND real context headroom. On a single consumer GPU:
#   - Prefer a coding/agent-tuned model that EITHER fits fully in VRAM (fast) OR is a low-active MoE
#     (spills to RAM but stays fast). A big DENSE model that doesn't fit is both slow and
#     context-starved — sessions overflow ("context size exceeded") on real multi-file tasks.
#   - Give the server enough context: set its window (e.g. llama.cpp `-c`) to >=32k, not ~16k.
# Example GGUF families to try (rename for your own hardware/VRAM): Devstral-Small, Qwen3-Coder, gpt-oss.

# Default model slug (override per run with --model).
LLM_MODEL=

# Optional: comma-separated models the smoke test exercises.
# LLM_SMOKE_MODELS=

# Optional: host-proxy upstream socket timeout in seconds (default 300). Raise for slow local models
# whose big-context turns exceed it (symptom: "upstream error: timed out" / 502 inside the VM).
# LLM_PROXY_TIMEOUT=300

# --- Local lane (ollama; see README "Local models") ---
# These are read from the environment, not this file (shown here for discoverability):
#   OLLAMA_BASE      base URL for local/llm.sh + local/queue.sh (default http://localhost:11434)
#   LLM_LOCAL_PORT   host port run_session.py --local-model tunnels into the VM (default 11434;
#                    e.g. 1234 for LM Studio)
